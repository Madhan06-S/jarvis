# ── AI BRAIN (at least one required; Pollinations is free fallback) ──────────
# Priority: OpenAI > Gemini > Claude > Pollinations (auto mode)
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Which AI to use for building websites (auto = best available)
# Options: auto | openai | gemini | claude | pollinations
AI_PROVIDER=auto

# Override model names (optional)
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── IMAGE GENERATION ─────────────────────────────────────────────────────────
# DALL-E 3 via OpenAI key above (free fallback = Pollinations)
